# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# IDE/editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Build/distribution
build/
dist/
*.egg-info/

# Data artifacts (keep folder structure, ignore contents)
data/raw/*
data/processed/*
data/spectrograms/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/spectrograms/.gitkeep
!data/processed/metrics.csv
!data/processed/ablation_results.csv

# Trained models and figures
models/*
figures/*
!models/.gitkeep
!figures/.gitkeep
!figures/*.png
!figures/cnn_architecture.png
!figures/ablation.png
!figures/metrics_comparison.png

# Large binary artifacts
*.npy
*.npz
*.pth
*.pkl
*.pt
